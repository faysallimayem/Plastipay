// Prisma Schema pour EcoCollect
// Système de collecte de bouteilles recyclables

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  phone        String?  @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  totalPoints   Int      @default(0) @map("total_points")
  role          String   @default("user") // user | admin
  profilePhoto  String?  @map("profile_photo")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  transactions     Transaction[]
  rewardRedemptions RewardRedemption[]

  @@map("users")
}

model Machine {
  id           Int      @id @default(autoincrement())
  name         String
  location     String
  serialNumber String   @unique @map("serial_number")
  apiKey       String   @unique @map("api_key")
  status       String   @default("active") // active | maintenance | offline
  lastPing     DateTime? @map("last_ping")
  createdAt    DateTime @default(now()) @map("created_at")

  transactions Transaction[]

  @@map("machines")
}

model Transaction {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  machineId    Int      @map("machine_id")
  bottlesCount Int      @map("bottles_count")
  bottleType   String   @default("plastic") @map("bottle_type") // plastic | glass
  pointsEarned Int      @map("points_earned")
  createdAt    DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  machine Machine @relation(fields: [machineId], references: [id])

  @@map("transactions")
}

model Reward {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  pointsCost  Int      @map("points_cost")
  category    String   @default("coffee") // coffee | discount | gift
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  redemptions RewardRedemption[]

  @@map("rewards")
}

model RewardRedemption {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  rewardId    Int      @map("reward_id")
  pointsSpent Int      @map("points_spent")
  couponCode  String?  @map("coupon_code")
  machineName String?  @map("machine_name")
  status      String   @default("pending") // pending | completed | cancelled
  createdAt   DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id])
  reward Reward @relation(fields: [rewardId], references: [id])

  @@map("reward_redemptions")
}
